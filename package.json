{
  "name": "@bounded-systems/anchored-chain-sqlite",
  "version": "0.2.1",
  "description": "SQLite/Drizzle-backed implementation of the anchored-chain stores",
  "bounded": {
    "tagline": "SQLite/Drizzle-backed implementation of the anchored-chain stores",
    "kind": "room"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/anchored-chain-sqlite.git"
  },
  "homepage": "https://github.com/bounded-systems/anchored-chain-sqlite#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/anchored-chain-sqlite/issues"
  },
  "keywords": [
    "anchored-chain",
    "provenance",
    "sqlite",
    "drizzle",
    "bun",
    "derivation-store"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bounded-systems/anchored-chain": "npm:@jsr/bounded-systems__anchored-chain",
    "@bounded-systems/cas": "npm:@jsr/bounded-systems__cas",
    "drizzle-orm": "^0.45.2"
  }
}
